{
  "name": "zest-web-ui",
  "version": "1.2.0",
  "description": "Production-ready React UI components styled with Tailwind CSS — tables, buttons, modals, inputs and more.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external react --external react-dom",
    "dev": "tsup src/index.ts --watch --dts --external react --external react-dom"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "tailwind",
    "table",
    "data-table",
    "modal",
    "button",
    "input",
    "select",
    "tabs",
    "spinner",
    "alert",
    "zest",
    "component-library",
    "typescript",
    "nextjs"
  ],
  "author": "PulseZest Innovation <deepanshu@pulsezest.com>",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PulseZest-Inovation/zest-web-ui.git"
  },
  "bugs": {
    "url": "https://github.com/PulseZest-Inovation/zest-web-ui/issues"
  },
  "homepage": "https://github.com/PulseZest-Inovation/zest-web-ui#readme",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    }
  }
}
